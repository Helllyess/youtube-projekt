{
  "id": "kanal_hauptkanal",
  "name": "Mein Hauptkanal",
  "platform": "youtube",
  "niche": "storytelling",
  "language": "de",
  "active": true,

  "upload": {
    "default_privacy": "private",
    "default_category": "25",
    "made_for_kids": false,
    "notify_subscribers": true,
    "schedule_delay_hours": 0
  },

  "script": {
    "target_duration_minutes": 8,
    "style": "educational_engaging",
    "language": "de"
  },

  "voiceover": {
    "provider": "fish_audio",
    "fish_voice_id": "54a5170264694bfc8e9ad98df7bd89c3"
  },

  "topics": [
    "Historische Schlachten und ihre geheimen Wendepunkte",
    "Faszinierende Biographien vergessener Genies",
    "Ungeklärte Mysterien der Weltgeschichte",
    "Wahre Verbrechen und dramatische Gerichtsverfahren",
    "Verrückte Wissenschafts-Experimente die alles verändert haben",
    "Kuriose Fakten die du nicht glauben wirst",
    "Verschwundene Zivilisationen und ihre Geheimnisse",
    "Die dunkelsten Kapitel der Geschichte",
    "Berühmte Betrüger und ihre unglaublichen Maschen",
    "Extreme Überlebensgeschichten die Geschichte schrieben"
  ],

  "default_tags": [
    "Geschichte", "Storytelling", "Doku", "Biographie", "Mystery",
    "True Crime", "Fakten", "Wissen", "History", "Geheimnisse"
  ],

  "branding": {
    "outro_text": "Abonniere für fesselnde Storys die du nirgendwo anders findest!",
    "watermark": false
  },

  "_ANLEITUNG": {
    "schritt1": "Ersetze 'youtube_client_secret.json' mit deiner OAuth-Datei von console.cloud.google.com",
    "schritt2": "Ändere 'name' zu deinem echten Kanalnamen",
    "schritt3": "Passe 'topics' und 'default_tags' an deinen Kanal an",
    "schritt4": "Starte: python main.py --channel kanal_hauptkanal"
  }
}
